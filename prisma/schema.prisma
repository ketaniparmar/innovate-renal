generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (Hardcoded System Constraints)
// ==========================================

enum UserRole {
  SUPER_ADMIN
  DIRECTOR
  FACILITY_MANAGER
  TECHNICIAN
  AUDITOR
}

enum InfectionStatus {
  NONE
  HCV_POSITIVE
  HBSAG_POSITIVE
  HIV_POSITIVE
}

enum MachineZone {
  GENERAL
  ISOLATION
}

enum SessionState {
  SCHEDULED
  READY
  IN_PROGRESS
  COMPLETED
  COMPLICATION
  CANCELLED
}

enum PayerType {
  CASH
  CORPORATE
  PM_JAY
  CGHS
  ESIC
}

enum DialyzerStatus {
  SAFE
  WARNING
  DISCARD_MANDATORY
  DISCARDED
}

// ==========================================
// AUTH, TENANCY & MULTI-CENTER STRUCTURE
// ==========================================

model Tenant {
  id          String     @id @default(uuid())
  name        String     // e.g., "Innovate India Renal Network"
  
  facilities  Facility[]
  projects    Project[]
  users       User[]
  
  createdAt   DateTime   @default(now())
}

model Facility {
  id          String     @id @default(uuid())
  tenantId    String
  name        String     // e.g., "Nova Lifeline Super Speciality"
  location    String
  state       String     // Crucial for regional single-use compliance
  
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  users       User[]
  machines    Machine[]
  patients    Patient[]
  sessions    Session[]
  leads       Lead[]     

  @@index([tenantId]) // ⚡ Speed upgrade for multi-tenant queries
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  fullName    String
  role        UserRole   @default(TECHNICIAN)
  
  tenantId    String
  facilityId  String?    // Null for multi-center Directors
  
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facility    Facility?  @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@index([tenantId])
  @@index([facilityId])
}

// ==========================================
// CORE CLINICAL ENTITIES
// ==========================================

model Patient {
  id              String          @id @default(uuid())
  facilityId      String
  uhid            String          @unique // Hospital ID
  fullName        String
  infectionStatus InfectionStatus @default(NONE)
  dialysisType    String          @default("HD") 
  dryWeightKg     Float?
  vascularAccess  String?         
  payerType       PayerType       @default(CASH)
  
  facility        Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  sessions        Session[]
  dialyzers       Dialyzer[]      
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([facilityId])
  @@index([uhid]) // ⚡ Speed upgrade for patient lookups
}

model Machine {
  id              String      @id @default(uuid())
  facilityId      String
  machineTag      String      // e.g., M-01
  zone            MachineZone @default(GENERAL)
  isActive        Boolean     @default(true)
  
  facility        Facility    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  sessions        Session[]

  @@unique([facilityId, machineTag]) 
  @@index([facilityId])
}

model Dialyzer {
  id              String         @id @default(uuid())
  barcode         String         @unique
  patientId       String
  currentUses     Int            @default(0)
  maxAllowedUses  Int            // Enforced by RegionalPolicy/Payer rules
  status          DialyzerStatus @default(SAFE)
  
  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime       @default(now())
  discardedAt     DateTime?

  @@index([patientId])
}

model Technician {
  id                   String    @id @default(uuid())
  techId               String    @unique // e.g., T-01
  fullName             String
  isIsolationQualified Boolean   @default(false)
  maxPatientLoad       Int       @default(4) // NABH standard cap
  
  sessions             Session[]
}

model Shift {
  id          String    @id @default(uuid())
  shiftName   String    // e.g., "Morning", "Afternoon"
  startTime   DateTime  @db.Time
  endTime     DateTime  @db.Time
  
  sessions    Session[]
}

// ==========================================
// THE EXECUTION LAYER (Events & State)
// ==========================================

model Session {
  id            String       @id @default(uuid())
  facilityId    String
  date          DateTime     @db.Date
  currentState  SessionState @default(SCHEDULED)
  
  patientId     String
  machineId     String
  technicianId  String
  shiftId       String
  
  facility      Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  machine       Machine      @relation(fields: [machineId], references: [id], onDelete: Restrict)
  technician    Technician   @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  shift         Shift        @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  
  clinicalData  ClinicalData?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([machineId, shiftId, date]) 
  @@index([facilityId, date]) // ⚡ Crucial for generating daily shift rosters quickly
  @@index([patientId])
}

model ClinicalData {
  id              String   @id @default(uuid())
  sessionId       String   @unique
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  preBpSystolic   Int?
  preBpDiastolic  Int?
  preWeightKg     Float?
  
  postBpSystolic  Int?
  postBpDiastolic Int?
  postWeightKg    Float?
  
  ufRemovedMl     Int?     
  notes           String?  @db.Text
  
  loggedAt        DateTime @default(now())
}

// ==========================================
// FRONTEND FUNNEL: LEAD CAPTURE & REGULATORY
// ==========================================

model Lead {
  id              String    @id @default(uuid()) // Added secure fallback
  facilityId      String?
  directorName    String?
  hospitalName    String?
  location        String
  intentType      String    
  machineCount    Int
  currentCost     Float?
  projectedCapex  Float?   
  status          String    @default("WHATSAPP_INITIATED") 
  userAgent       String?
  ipAddress       String?
  
  facility        Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt 
}

model RegionalPolicy {
  id              String   @id @default(uuid())
  state           String   @unique
  singleUseForced Boolean  @default(false)
  pmjayMaxReuse   Int      @default(1)
  wholesalePrice  Float
  retailBaseline  Float
}

// ==========================================
// FINANCIAL UNDERWRITING ENGINE
// ==========================================

model Project {
  id            String       @id @default(uuid())
  tenantId      String
  name          String
  machines      Int
  cityTier      Int
  tdsLevel      Int
  
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  simulations   Simulation[]
  
  createdAt     DateTime     @default(now())

  @@index([tenantId])
}

model Simulation {
  id              String   @id @default(uuid())
  projectId       String
  viewMode        String
  cityTier        String
  machineCount    Int
  occupancyRate   Float
  pmjayMix        Float
  cghsMix         Float
  cashMix         Float
  insuranceMix    Float
  includesAMC     Boolean
  includesDiacare Boolean
  isNABH          Boolean  @default(true) // ⚡ Required for accurate CAPEX math
  
  monthlyRevenue  Float
  monthlyOpex     Float
  monthlyEbitda   Float
  ebitdaMargin    Float
  paybackMonths   Float
  investmentGrade String
  workingCapital  Float
  irr             Float
  totalCapex      Float
  
  status          String   @default("PENDING")
  reportPath      String?  // ⚡ Required to store the generated DPR PDF link
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())

  @@index([projectId])
}