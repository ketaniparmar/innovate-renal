generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]

  @@map("tenants")
}

model Project {
  id          String       @id @default(cuid())
  name        String
  location    String?
  machines    Int          @default(0)
  beds        Int          @default(0)
  cityTier    Int          @default(2)
  tdsLevel    Int          @default(500)
  mode        String?
  pmjayPct    Float?       @default(0)
  pvtPct      Float?       @default(0)
  tenantId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  simulations Simulation[]

  @@map("projects")
}

model Simulation {
  id           String   @id @default(cuid())
  totalCapex   Float
  annualEbitda Float?
  irr          Float
  dscr         Float?
  creditRating String?
  npv          Float?   @default(0)
  projectId    String
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("simulations")
}
