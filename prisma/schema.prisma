generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (Hardcoded System Constraints)
// ==========================================

enum UserRole {
  SUPER_ADMIN
  DIRECTOR
  FACILITY_MANAGER
  TECHNICIAN
  AUDITOR
}

enum InfectionStatus {
  NONE
  HCV_POSITIVE
  HBSAG_POSITIVE
  HIV_POSITIVE
}

enum MachineZone {
  GENERAL
  ISOLATION
}

enum SessionState {
  SCHEDULED
  READY
  IN_PROGRESS
  COMPLETED
  COMPLICATION
  CANCELLED
}

enum PayerType {
  CASH
  CORPORATE
  PM_JAY
  CGHS
  ESIC
}

enum DialyzerStatus {
  SAFE
  WARNING
  DISCARD_MANDATORY
  DISCARDED
}

// ==========================================
// AUTH, TENANCY & MULTI-CENTER STRUCTURE
// ==========================================

model Tenant {
  id          String     @id @default(uuid())
  name        String     // e.g., "Innovate India Renal Network"
  facilities  Facility[]
  projects    Project[]
  users       User[]
  createdAt   DateTime   @default(now())
}

model Facility {
  id          String     @id @default(uuid())
  tenantId    String
  name        String     // e.g., "Dahej Public Hospital"
  location    String
  state       String     // For regional compliance limits
  
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  machines    Machine[]
  patients    Patient[]
  sessions    Session[]
  leads       Lead[]     // Tracks leads generated for or assigned to this facility
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  fullName    String
  role        UserRole   @default(TECHNICIAN)
  
  tenantId    String
  facilityId  String?    // Null if it's a multi-center Director/Admin
  
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  facility    Facility?  @relation(fields: [facilityId], references: [id])
  
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

// ==========================================
// CORE CLINICAL ENTITIES
// ==========================================

model Patient {
  id              String          @id @default(uuid())
  facilityId      String
  uhid            String          @unique // Hospital ID
  fullName        String
  infectionStatus InfectionStatus @default(NONE)
  dialysisType    String          @default("HD") // HD, SLED
  dryWeightKg     Float?
  vascularAccess  String?         // AVF, Catheter
  payerType       PayerType       @default(CASH)
  
  facility        Facility        @relation(fields: [facilityId], references: [id])
  sessions        Session[]
  dialyzers       Dialyzer[]      // Tracks historical and active dialyzers
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Machine {
  id              String      @id @default(uuid())
  facilityId      String
  machineTag      String      // e.g., M-01
  zone            MachineZone @default(GENERAL)
  isActive        Boolean     @default(true)
  
  facility        Facility    @relation(fields: [facilityId], references: [id])
  sessions        Session[]

  @@unique([facilityId, machineTag]) // M-01 is unique per facility
}

model Dialyzer {
  id              String         @id @default(uuid())
  barcode         String         @unique
  patientId       String
  currentUses     Int            @default(0)
  maxAllowedUses  Int            // Enforced by RegionalPolicy/Payer rules
  status          DialyzerStatus @default(SAFE)
  
  patient         Patient        @relation(fields: [patientId], references: [id])
  
  createdAt       DateTime       @default(now())
  discardedAt     DateTime?
}

model Technician {
  id                   String    @id @default(uuid())
  techId               String    @unique // e.g., T-01
  fullName             String
  isIsolationQualified Boolean   @default(false)
  maxPatientLoad       Int       @default(4) // Hard cap for safety
  
  sessions             Session[]
}

model Shift {
  id          String    @id @default(uuid())
  shiftName   String    // e.g., "Morning", "Afternoon"
  startTime   DateTime  @db.Time
  endTime     DateTime  @db.Time
  
  sessions    Session[]
}

// ==========================================
// THE EXECUTION LAYER (Events & State)
// ==========================================

model Session {
  id            String       @id @default(uuid())
  facilityId    String
  date          DateTime     @db.Date
  currentState  SessionState @default(SCHEDULED)
  
  // Foreign Keys
  patientId     String
  machineId     String
  technicianId  String
  shiftId       String
  
  // Relations
  facility      Facility     @relation(fields: [facilityId], references: [id])
  patient       Patient      @relation(fields: [patientId], references: [id])
  machine       Machine      @relation(fields: [machineId], references: [id])
  technician    Technician   @relation(fields: [technicianId], references: [id])
  shift         Shift        @relation(fields: [shiftId], references: [id])
  
  // Clinical Data (One-to-One)
  clinicalData  ClinicalData?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Database-level constraint to prevent double-booking a machine in a shift
  @@unique([machineId, shiftId, date]) 
}

model ClinicalData {
  id              String   @id @default(uuid())
  sessionId       String   @unique
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Pre-Vitals (Required to start)
  preBpSystolic   Int?
  preBpDiastolic  Int?
  preWeightKg     Float?
  
  // Post-Vitals (Required to finish / claim)
  postBpSystolic  Int?
  postBpDiastolic Int?
  postWeightKg    Float?
  ufRemovedMl     Int?     // Crucial for PM-JAY billing
  
  notes           String?  @db.Text
  loggedAt        DateTime @default(now())
}

// ==========================================
// FRONTEND FUNNEL: LEAD CAPTURE & REGULATORY
// ==========================================

model Lead {
  id              String    @id // Accepting client-generated crypto.randomUUID()
  facilityId      String?
  directorName    String?
  hospitalName    String?
  location        String
  intentType      String    // "CAPEX_NEW_SETUP" or "OPEX_SUPPLY"
  machineCount    Int
  currentCost     Float?   
  projectedCapex  Float?   
  status          String    @default("WHATSAPP_INITIATED") 
  userAgent       String?   // Tracks device/browser for funnel analytics
  ipAddress       String?   // Tracks regional origin
  
  facility        Facility? @relation(fields: [facilityId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt // Critical for tracking offline retries
}

model RegionalPolicy {
  id              String   @id @default(uuid())
  state           String   @unique
  singleUseForced Boolean  @default(false)
  pmjayMaxReuse   Int      @default(1)
  wholesalePrice  Float
  retailBaseline  Float
}

// ==========================================
// FINANCIAL UNDERWRITING ENGINE
// ==========================================

model Project {
  id            String       @id @default(uuid())
  tenantId      String
  name          String
  machines      Int
  cityTier      Int
  tdsLevel      Int
  
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  simulations   Simulation[]
  
  createdAt     DateTime     @default(now())
}

model Simulation {
  id              String   @id @default(uuid())
  projectId       String
  viewMode        String
  cityTier        String
  machineCount    Int
  occupancyRate   Float
  pmjayMix        Float
  cghsMix         Float
  cashMix         Float
  insuranceMix    Float
  includesAMC     Boolean
  includesDiacare Boolean
  
  monthlyRevenue  Float
  monthlyOpex     Float
  monthlyEbitda   Float
  ebitdaMargin    Float
  paybackMonths   Float
  investmentGrade String
  workingCapital  Float
  irr             Float
  totalCapex      Float
  status          String
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}